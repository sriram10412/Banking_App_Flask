# =============================================================================
# Banking App – .gitignore
# Covers: Terraform, Python, Docker, AWS, IDE files
# =============================================================================

# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------

# Local .terraform directory (downloaded providers & modules)
**/.terraform/
**/.terraform.lock.hcl

# Terraform state files – NEVER commit these (contain secrets)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan output files
*.tfplan
tfplan
*.plan



# Exception: commit the example/template tfvars
!environments/prod/terraform.tfvars.example

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# Terraform plugin cache
.terraform.d/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.coveragerc
junit*.xml
test-results/

# MyPy / type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Bandit security report
bandit-report.json

# -----------------------------------------------------------------------------
# Environment & Secrets – CRITICAL: never commit these
# -----------------------------------------------------------------------------

.env
.env.*
.env.local
.env.production
.env.staging
!.env.example

*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets.yml
secrets.yaml
secrets.json
*secrets*
*credentials*

# AWS credentials
.aws/
aws-credentials.json

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------

.dockerignore.local

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Logs & temp files
# -----------------------------------------------------------------------------

*.log
logs/
tmp/
temp/
.tmp/

# -----------------------------------------------------------------------------
# CI / CD artifacts
# -----------------------------------------------------------------------------

gl-container-scanning-report.json
trivy-report.json
tfsec-report.xml
.sonar/
.scannerwork/
.gitlab-ci-cache/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------

*.zip
*.tar.gz
*.tar
*.gz

node_modules/
npm-debug.log*